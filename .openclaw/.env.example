# OpenClaw Docker Environment
# Copy this file to ~/.openclaw-docker/.env and fill in real values
# Then run: chmod 600 ~/.openclaw-docker/.env

OPENCLAW_GATEWAY_TOKEN=GENERATE_WITH_openssl_rand_-hex_32

# AI Model API Keys
ANTHROPIC_API_KEY=REPLACE_ME
OPENAI_API_KEY=REPLACE_ME
GOOGLE_API_KEY=REPLACE_ME

# Docker compose variables — adjust paths for your system
OPENCLAW_CONFIG_DIR=REPLACE_WITH_HOME/.openclaw-docker/config
OPENCLAW_WORKSPACE_DIR=REPLACE_WITH_HOME/.openclaw-docker/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
